# API server (Express). Copy to .env in this folder or load from process manager.
PORT=5000

# MongoDB Atlas connection string.
DATABASE_URL=
MONGODB_DB_NAME=visiting_cards

JWT_SECRET=change-me-to-a-long-random-string
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
CLIENT_NAME=Client User
CLIENT_EMAIL=client@example.com
CLIENT_PASSWORD=change-this-client-password

# Google Gemini (AI Studio / GenAI API)
GEMINI_API_KEY=

# Optional: custom base URL (legacy Replit AI proxy). Leave unset for default Google endpoint.
# GEMINI_API_BASE_URL=
